/* * lexer.l: Lexical analyzer for the Sci-PL language 
 * (For use with Flex)
 */
 
%{
#include <stdio.h>
#include <stdlib.h> // For atof(), atoi()
#include <string.h> // For strdup()

/* This header is generated by Bison/Yacc and contains token definitions */
#include "y.tab.h" 

/* Function prototype for the parser's error reporting */
extern void yyerror(const char *s); 
%}

/* * Flex options:
 * yylineno: Automatically track line numbers.
 */
%option yylineno

/* * Named Regular Expressions (Definitions) 
 * [cite_start]These are based on the language overview [cite: 496, 504-512].
 */
digit         [0-9]
integer       {digit}+
float_lit     {integer}\.{integer}
letter        [a-zA-Z]
identifier    {letter}({letter}|{digit}|_)*

/* A reaction literal is a string. This rule will strip the quotes. */
reaction_lit  \"[^\"]*\"


%%
/* * Rules Section:
 * Patterns are matched, and C code (actions) is executed.
 * Keywords MUST come before the 'identifier' rule.
 */
 
/* --- Whitespace and Newlines --- */
[ \t\r]+      { /* Skip all whitespace */ }
\n            { /* Skip newline, yylineno is auto-incremented */ }


/* --- Keywords --- */
"main"          { return T_MAIN; }
"def"           { return T_DEF; }
"int"           { return T_INT; }
"float"         { return T_FLOAT; }
"bool"          { return T_BOOL; }
"reaction"      { return T_REACTION; }
"if"            { return T_IF; }
"else"          { return T_ELSE; }
"while"         { return T_WHILE; }
[cite_start]"check_balance" { return T_CHECK_BALANCE; } /* Special operator [cite: 511] */


/* --- Literals (with value passing) --- */
{float_lit}     { 
                    yylval.fval = atof(yytext); 
                    return T_FLOAT_LITERAL; 
                }
                
{integer}       { 
                    yylval.ival = atoi(yytext); 
                    return T_INT_LITERAL; 
                }
                
{reaction_lit}  { 
                    /* Copy the string, but strip the outer quotes */
                    int len = strlen(yytext);
                    char *str = strdup(yytext + 1); /* +1 to skip opening " */
                    str[len - 2] = '\0';            /* -2 to remove closing " */
                    yylval.sval = str;
                    return T_REACTION_LITERAL; 
                }

/* --- Identifier (with value passing) --- */
{identifier}    { 
                    yylval.sval = strdup(yytext); 
                    return T_ID; 
                }


/* --- Operators and Punctuation --- */
"="             { return T_ASSIGN; }
"+"             { return T_PLUS; }
"-"             { return T_MINUS; }
"*"             { return T_STAR; }
"/"             { return T_SLASH; }
">"             { return T_GT; }
"<"             { return T_LT; }
"&&"            { return T_AND; }
"||"            { return T_OR; }
"{"             { return T_LBRACE; }
"}"             { return T_RBRACE; }
"("             { return T_LPAREN; }
")"             { return T_RPAREN; }
";"             { return T_SEMICOLON; }
","             { return T_COMMA; }


/* --- Error Handling --- */
.               { 
                    char err[100];
                    sprintf(err, "Line %d: Unrecognized character '%s'", yylineno, yytext);
                    yyerror(err);
                }

%%
/*
 * User Code Section
 */

/* * This function is called by 'flex' when it reaches the end of the file.
 * Returning 1 indicates that we are done.
 */
int yywrap(void) {
    return 1;
}